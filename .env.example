# =============================================================================
# Copie para .env na raiz e ajuste conforme seu ambiente.
# Após editar, reinicie: uvicorn app.main:app --reload
# =============================================================================

# --- Container Docker (recomendado para desenvolvimento) ---
# Sobe com:  cd docker && docker compose up -d
# Banco "SistemaAcademico" é criado e populado automaticamente.
DATABASE_URL=mssql+pyodbc://sa:SenhaForte!123@localhost:1433/SistemaAcademico?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# --- Windows Authentication (instância local) ---
# DATABASE_URL=mssql+pyodbc://@localhost/SistemaAcademico?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes&Trusted_Connection=yes

# --- SQL Server Express nomeado ---
# DATABASE_URL=mssql+pyodbc://@localhost\SQLEXPRESS/SistemaAcademico?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes&Trusted_Connection=yes

# Se não tiver Driver 18, troque por: ODBC+Driver+17+for+SQL+Server

SECRET_KEY=altere-esta-chave-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

API_V1_PREFIX=/api/v1
PROJECT_NAME=Sistema Acadêmico Escolar
DEBUG=true

CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500
